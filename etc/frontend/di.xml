<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!--
        PLP badge rendering: ImageFactory builds the Image block for every
        product tile; the plugin attaches the product's labels and swaps in a
        template that wraps the stock markup with the badge overlay.
    -->
    <type name="Magento\Catalog\Block\Product\ImageFactory">
        <plugin name="magendoo_productlabels_image_labels"
                type="Magendoo\ProductLabels\Plugin\Catalog\AddLabelsToImagePlugin"/>
    </type>
</config>
